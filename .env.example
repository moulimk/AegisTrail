# AegisTrail — copy to .env and fill in. NEVER commit .env.

# --- Postgres (detector state store) ---
POSTGRES_PASSWORD=change_me_dev_pw

# --- Detector service ---
# SAFE_MODE=true  -> /contain returns an action PLAN only, never executes (default).
# SAFE_MODE=false -> execute scoped identity actions (Phase 3 only).
SAFE_MODE=true
LOG_LEVEL=info

# Round 2 #1 — protected-identity allowlist. The responder must NEVER act on these.
# Comma-separated usernames/ARNs. Keep root + any break-glass admin here.
PROTECTED_IDENTITIES=root,break-glass-admin

# --- AI triage (Phase 2b) — provider-agnostic ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
TRIAGE_MODEL=gpt-4o-mini
# Anthropic alternative:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# TRIAGE_MODEL=claude-haiku-4-5

# --- Notifications ---
SLACK_WEBHOOK_URL=

# --- Enrichment (optional) ---
# ip-api.com needs no key at low volume; AbuseIPDB / MaxMind GeoLite2 are optional.
ABUSEIPDB_API_KEY=

# --- AWS (Phase 3 containment) — leave blank for SAFE_MODE demos ---
# Use a SCOPED, least-privilege containment role. Never root or admin keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
